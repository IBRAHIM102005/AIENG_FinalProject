# ============================================================
# Python runtime / compiled
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ============================================================
# Virtual environments (local only)
# ============================================================
.venv/
venv/
env/

# ============================================================
# Environment & secrets (NEVER COMMIT)
# ============================================================
.env
.env.*
*.key
*.pem
secrets/

# ============================================================
# Build / packaging
# ============================================================
build/
dist/
*.egg-info/

# ============================================================
# Testing / coverage
# ============================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ============================================================
# Lint / type-check caches
# ============================================================
.mypy_cache/
.ruff_cache/
.pyright/

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# AI pipeline artifacts (CRITICAL for your project)
# ============================================================

